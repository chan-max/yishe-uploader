{
    "name": "yishe-auto-browser",
    "version": "2.0.211",
    "description": "Yishe Auto Browser - Browser automation API for auto-publish and related operations",
    "main": "src/index.js",
    "type": "module",
    "scripts": {
        "dev": "npm run web:build && node --watch src/api/server.js",
        "dev:no-watch": "npm run web:build && node src/api/server.js",
        "web:build": "vite build --config web/vite.config.js",
        "ecom:smoke": "node scripts/ecom-smoke.js",
        "build:exe": "node scripts/build-exe.js",
        "build:installer": "node scripts/build-installer.js",
        "build:dist": "npm run build:exe && npm run build:installer"
    },
    "keywords": [
        "social-media",
        "automation",
        "puppeteer",
        "upload",
        "weibo",
        "douyin",
        "xiaohongshu",
        "kuaishou"
    ],
    "author": "Jc",
    "license": "MIT",
    "dependencies": {
        "adm-zip": "^0.5.16",
        "axios": "^1.10.0",
        "chalk": "^5.3.0",
        "commander": "^12.0.0",
        "fs-extra": "^11.2.0",
        "inquirer": "^9.2.15",
        "ora": "^8.0.1",
        "pinia": "^2.1.7",
        "playwright-core": "^1.55.0",
        "vue": "^3.4.0",
        "vue-router": "^4.2.5"
    },
    "devDependencies": {
        "@vitejs/plugin-vue": "^5.0.0",
        "esbuild": "^0.24.0",
        "nexe": "^4.0.0-rc.6",
        "sass": "^1.69.5",
        "semantic-ui-css": "^2.5.0",
        "vite": "^5.0.0"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
